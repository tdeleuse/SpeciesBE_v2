@page "/login"
@layout EmptyLayout
@inject AuthService AuthService
@inject NavigationManager Nav

@* Page de connexion plein écran sans navbar *@
<div class="login-fullscreen">

    <div class="login-card">

        @* LOGO *@
        <div class="text-center mb-4">
            <div style="font-size:3.5rem; line-height:1;">🌿</div>
            <h1 style="font-family:'Playfair Display',serif; color:var(--green-dark); font-size:2rem; margin-top:0.5rem;">
                Species
            </h1>
            <p class="text-muted small mt-1">Explorez le monde du vivant</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(error))
        {
            <div class="alert alert-danger py-2 small">@error</div>
        }

        @* CHAMP NOM *@
        <div class="mb-3">
            <label class="form-label fw-bold" style="color:var(--green-dark);">
                Nom d'utilisateur
            </label>
            <input class="form-control form-control-lg"
                   @bind="username"
                   @bind:event="oninput"
                   @onkeydown="OnKeyDown"
                   placeholder="ex: alice"
                   maxlength="30" />
            <div class="form-text">Aucun mot de passe requis — ton nom suffit.</div>
        </div>

        @* BOUTON CONNEXION *@
        <button class="btn btn-primary w-100 py-3 mt-2"
                @onclick="DoLogin"
                disabled="@(string.IsNullOrWhiteSpace(username))">
            Se connecter →
        </button>

        @* SÉPARATEUR *@
        <div class="d-flex align-items-center my-4 gap-3">
            <hr class="flex-grow-1 m-0" />
            <span class="text-muted small fw-bold">ou</span>
            <hr class="flex-grow-1 m-0" />
        </div>

        @* CONTINUER EN INVITÉ *@
        <button class="btn btn-outline-primary w-100 py-2"
                @onclick="ContinueAsGuest">
            🔍 Continuer sans compte
        </button>

        <p class="text-center text-muted mt-4 mb-0" style="font-size:0.78rem;">
            En tant qu'invité, la sauvegarde de favoris n'est pas disponible.
        </p>
    </div>

</div>

@code {
    private string username = "";
    private string? error;

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(username))
            await DoLogin();
    }

    private async Task DoLogin()
    {
        var trimmed = username.Trim();
        if (string.IsNullOrWhiteSpace(trimmed))
        {
            error = "Entre un nom d'utilisateur.";
            return;
        }
        error = null;
        await AuthService.LoginAsync(trimmed);
        Nav.NavigateTo("/dashboard");
    }

    private void ContinueAsGuest()
    {
        Nav.NavigateTo("/dashboard");
    }
}
